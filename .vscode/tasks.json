{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run pytest tests",
            "type": "shell",
            "command": "uv run pytest ${input:pytestArgs}",
            "group": "test"
        },
        {
            "label": "Build native tests",
            "type": "shell",
            "command": "uv run --no-sync cmake --build ${env:EXT_BUILD_DIR} -t graph_test",
            "group": "build"
        },
        {
            "label": "Run native tests with ctest",
            "type": "shell",
            "command": "uv run --no-sync ctest --test-dir ${env:EXT_BUILD_DIR} --output-on-failure",
            "group": "test",
            "dependsOn": "Build native tests"
        }
    ],
    "inputs": [
        {
            "type": "promptString",
            "id": "pytestArgs",
            "description": "Additional arguments to pass to pytest",
            "default": ""
        }
    ]
}